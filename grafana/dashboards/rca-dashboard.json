{
  "title": "AI RCA System",
  "panels": [
    {
      "type": "logs",
      "title": "Application Logs",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": "Loki",
      "targets": [{"expr": "{job=\"flask-app\"}"}]
    },
    {
      "type": "logs",
      "title": "Errors Only",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "datasource": "Loki",
      "targets": [{"expr": "{job=\"flask-app\"} |= \"ERROR\""}]
    },
    {
      "type": "stat",
      "title": "Total HTTP Requests",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "datasource": "Prometheus",
      "targets": [{"expr": "http_requests_total"}]
    },
    {
      "type": "stat",
      "title": "Total Errors",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
      "datasource": "Prometheus",
      "targets": [{"expr": "app_errors_total"}]
    }
  ],
  "schemaVersion": 16,
  "version": 1
}